# Optional. ContextFill is fully functional without a key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6
CONTEXTFILL_SERVICE_PORT=4318

# Optional legacy pairing. New installations use the one-time terminal code instead.
CONTEXTFILL_EXTENSION_ID=

# Set to 1 for one service start to clear a lost pairing and print a new code.
CONTEXTFILL_PAIRING_RESET=0

# Both providers redirect back to this loopback origin. Register the exact callback URL shown in
# docs/MAILBOX_INTEGRATION.md with the provider application.
CONTEXTFILL_OAUTH_REDIRECT_ORIGIN=http://localhost:4318

# Gmail API OAuth web client. gmail.readonly is requested; refresh authorization uses the OS keychain.
CONTEXTFILL_GOOGLE_CLIENT_ID=
CONTEXTFILL_GOOGLE_CLIENT_SECRET=

# Microsoft Entra public client. Use common for personal plus work/school accounts.
CONTEXTFILL_MICROSOFT_CLIENT_ID=
CONTEXTFILL_MICROSOFT_TENANT=common
