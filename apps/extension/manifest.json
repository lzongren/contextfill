{
  "manifest_version": 3,
  "name": "ContextFill",
  "version": "0.2.0.7",
  "version_name": "0.2.0-beta.7",
  "description": "Verifies message, destination, and site context before an explicit temporary action.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:4318/*", "http://127.0.0.1:4173/*"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_title": "Open ContextFill",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1/*"],
      "js": ["capsule-content.js"],
      "run_at": "document_idle"
    }
  ],
  "minimum_chrome_version": "114"
}
